{
  "_comment": "Lancet2 Claude Code settings — aggressive hook profile. See .claude/hooks/README.md for what each hook does and why. The Edit(...) deny rules below mirror .claude/protected_paths.txt; that file is the single source of truth, and the /audit-bundle slash command verifies the two stay in sync. Note on deletions: rm/rmdir/shred are NOT in deny, so Claude Code prompts the user per-invocation. The block_dangerous_bash hook validates path safety before the prompt is shown — only deletions whose paths land under /tmp/, /var/tmp/, /scratch/, or a gitignored path inside the project root reach the user-approval prompt; everything else is blocked at the hook layer. git push and git reset --hard origin remain blanket-blocked because they have no safe variant for an autonomous agent.",

  "autoUpdatesChannel": "stable",

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/block_protected_paths.py\""
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate_layer_direction.py\""
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate_naming.py\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/block_dangerous_bash.py\""
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate_commit_message.py\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre_commit_summary.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre_commit_gate.sh\""
          }
        ]
      }
    ],

    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && bash .claude/hooks/stop_reminder.sh"
          }
        ]
      }
    ]
  },

  "permissions": {
    "deny": [
      "Bash(git push:*)",
      "Bash(git reset --hard origin*:*)",
      "Edit(cmake-build-*/**)",
      "Edit(_deps/**)",
      "Edit(.pixi/**)",
      "Edit(.worktrees/**)",
      "Edit(.git/**)",
      "Edit(cmake/**)",
      "Edit(Dockerfile)",
      "Edit(pixi.lock)",
      "Edit(pixi.toml)",
      "Edit(.github/**)",
      "Edit(data/**)",
      "Edit(.chglog/**)",
      "Edit(CHANGELOG.md)",
      "Edit(LICENSE)"
    ]
  }
}
