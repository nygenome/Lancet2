# ----------------------------------------------------------------------------
# C/C++ build artifacts
# ----------------------------------------------------------------------------
# Object files, libraries, debug symbols, binaries produced by clang.
# Lancet2 is a C++20 codebase built with clang+libcxx via pixi-driven cmake.

# Compiled object files
*.d
*.slo
*.lo
*.o
*.obj
*.ko
*.elf

# Precompiled headers
*.gch
*.pch

# Dynamic libraries
*.so
*.so.*
*.dylib
*.dll

# Static libraries
*.lai
*.la
*.a
*.lib

# Linker output
*.ilk
*.map
*.exp

# Executables
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

# Debug symbols
*.dSYM/
*.su
*.idb
*.pdb


# ----------------------------------------------------------------------------
# CMake build outputs
# ----------------------------------------------------------------------------
# Pixi drives cmake builds into prefixed directories (build*, cmake-build-*).

build*/
cmake-build-*/

CMakeLists.txt.user
CMakeCache.txt
CMakeFiles
CMakeScripts
Testing
Makefile
cmake_install.cmake
install_manifest.txt
compile_commands.json
CTestTestfile.cmake
_deps


# ----------------------------------------------------------------------------
# Vim editor state
# ----------------------------------------------------------------------------
# Swap, session, and undo files for Vim users. The !*.svg negation keeps
# vector files in docs/assets/ tracked.

# Swap files
[._]*.s[a-v][a-z]
!*.svg
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]

# Session files
Session.vim
Sessionx.vim

# Temporary files
.netrwhist

# Auto-generated tag files
tags

# Persistent undo
[._]*.un~


# ----------------------------------------------------------------------------
# Other IDE / editor state
# ----------------------------------------------------------------------------
# Per-developer IDE workspace files.

.vscode/
*.iws


# ----------------------------------------------------------------------------
# Linux / Unix system noise
# ----------------------------------------------------------------------------
# Temporary and hidden files from Linux dev environments.

*~
.fuse_hidden*
.Trash-*
.nfs*


# ----------------------------------------------------------------------------
# macOS system noise
# ----------------------------------------------------------------------------
# Filesystem metadata and volume artifacts created by macOS.

# General
.DS_Store
.AppleDouble
.LSOverride

# Icon must end with two \r
Icon

# Resource forks (AFP/SMB shares)
._*

# Files that might appear in the root of a volume
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Directories potentially created on remote AFP share
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk


# ----------------------------------------------------------------------------
# Python build/test artifacts
# ----------------------------------------------------------------------------
# Lancet2 has Python helper scripts in scripts/ and python/.
# Pixi orchestrates Python tasks via the .pixi virtual environment.

# Compiled Python
__pycache__/
*.py[codz]
*$py.class

# Distribution / packaging (defensive coverage for Python setup.py-style builds)
.Python
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
!.claude/hooks/lib/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller (defensive)
*.manifest
*.spec

# Installer / pip logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py.cover
.hypothesis/
.pytest_cache/
cover/

# Translations (defensive)
*.mo
*.pot

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# Pixi virtual environment
.pixi/*
!.pixi/config.toml

# Generic Python virtual environments
.env
.envrc
.venv
env/
venv/
ENV/
env.bak/
venv.bak/


# ----------------------------------------------------------------------------
# Documentation builds
# ----------------------------------------------------------------------------
# Lancet2 mkdocs site builds to /site at repo root.

/site


# ----------------------------------------------------------------------------
# Lancet2 test datasets
# ----------------------------------------------------------------------------
# Test BAM/VCF datasets are large; tracked separately from the codebase.
# The download_test_data.sh script IS tracked so contributors can fetch them.

data/**
!data/download_test_data.sh


# ----------------------------------------------------------------------------
# Claude Code internal state
# ----------------------------------------------------------------------------
# Per-session and per-developer Claude Code state that should not be committed.

# Claude Code internal directories
.claude/worktrees/
.claude/projects/
.claude/cache/

# Per-developer settings (paths to test data, local API keys, etc.)
.claude/settings.local.json

# User-scoped agent memory: perf-analyst's observations are tied to specific
# hardware/kernel/BIOS conditions and don't generalize across the team.
# The other agent-memory files (project-scoped) ARE tracked.
.claude/agent-memory/perf-analyst.md

# Profile captures (binary, large)
*cpu_profile*.bin
*.prof

# Notes area used by Claude Code skills and slash commands.
# Claude is free to write into these subdirectories without triggering
# protected-path hooks; gitignoring keeps experimental work and feature-spec
# drafts out of git status. notes/** is recursive.
notes/**

# Feature worktrees created by /spec when the user opts in.
# The directory is bundle-protected via .claude/protected_paths.txt and
# gitignored here so worktree state does not appear in git status of the
# main checkout.
.worktrees/

# /fix-and-validate writes .claude/cache/validation-state.txt with four
# key=value fields: stash_hash, head_sha, timestamp, status. pre_commit_gate.sh
# reads stash_hash; statusline.sh reads status. Per-session state, already
# covered by .claude/cache/ above.
