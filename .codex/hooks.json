{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 '/Users/rajeevamusunuri/CLionProjects/Lancet2/.codex/hooks/block_protected_paths.py'"
          },
          {
            "type": "command",
            "command": "python3 '/Users/rajeevamusunuri/CLionProjects/Lancet2/.codex/hooks/validate_layer_direction.py'"
          },
          {
            "type": "command",
            "command": "python3 '/Users/rajeevamusunuri/CLionProjects/Lancet2/.codex/hooks/validate_cpp_identifiers.py'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 '/Users/rajeevamusunuri/CLionProjects/Lancet2/.codex/hooks/block_dangerous_bash.py'"
          },
          {
            "type": "command",
            "command": "python3 '/Users/rajeevamusunuri/CLionProjects/Lancet2/.codex/hooks/validate_commit_message.py'"
          },
          {
            "type": "command",
            "command": "bash '/Users/rajeevamusunuri/CLionProjects/Lancet2/.codex/hooks/pre_commit_summary.sh'"
          },
          {
            "type": "command",
            "command": "bash '/Users/rajeevamusunuri/CLionProjects/Lancet2/.codex/hooks/pre_commit_gate.sh'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && bash '/Users/rajeevamusunuri/CLionProjects/Lancet2/.codex/hooks/stop_reminder.sh'"
          }
        ]
      }
    ]
  }
}
